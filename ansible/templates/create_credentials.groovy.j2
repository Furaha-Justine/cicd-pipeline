import com.cloudbees.plugins.credentials.*
import com.cloudbees.plugins.credentials.domains.*
import com.cloudbees.plugins.credentials.impl.*
import com.cloudbees.jenkins.plugins.sshcredentials.impl.*

def store = SystemCredentialsProvider.getInstance().getStore()

// registry_creds — Docker Hub (required by lab)
store.addCredentials(Domain.global(), new UsernamePasswordCredentialsImpl(
    CredentialsScope.GLOBAL,
    "registry_creds",
    "Docker Hub credentials",
    "{{ docker_hub_user }}",
    "{{ docker_hub_token }}"
))

// ec2_ssh — SSH key for App EC2 (required by lab)
store.addCredentials(Domain.global(), new BasicSSHUserPrivateKey(
    CredentialsScope.GLOBAL,
    "ec2_ssh",
    "ec2-user",
    new BasicSSHUserPrivateKey.DirectEntryPrivateKeySource(
        new File("/var/lib/jenkins/.ssh/ec2_key.pem").text
    ),
    "",
    "EC2 SSH key"
))

// git_credentials — GitHub (optional, only needed for private repos)
{% if github_token is defined %}
store.addCredentials(Domain.global(), new UsernamePasswordCredentialsImpl(
    CredentialsScope.GLOBAL,
    "git_credentials",
    "GitHub credentials",
    "{{ github_user }}",
    "{{ github_token }}"
))
{% endif %}

println "Jenkins credentials created successfully"
